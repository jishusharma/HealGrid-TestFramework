  "type": "object",
  "required": ["id", "name", "username", "email", "phone", "website"],
  "properties": {
    "id":       { "type": "integer" },
    "name":     { "type": "string"  },
    "username": { "type": "string"  },
    "email":    { "type": "string"  },
    "phone":    { "type": "string"  },
    "website":  { "type": "string"  }
  }
}