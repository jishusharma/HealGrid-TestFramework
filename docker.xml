<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Docker Test Suite" parallel="classes" thread-count="3">
    <listeners>
        <listener class-name="utils.listeners.TestListener"/>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>
    <test name="Demo QA Tests" parallel="classes" thread-count="3">
        <classes>
            <class name="tests.DemoQAMainPageTest"/>
            <class name="tests.DemoQAElementsPageTest"/>
        </classes>
    </test>
</suite>
